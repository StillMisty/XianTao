<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="top.stillmisty.xiantao.infrastructure.mapper.ItemTemplateMapper">

    <!-- 根据多个标签查找物品模板（包含任一标签，使用 ?| 操作符） -->
    <select id="selectByAnyTags" resultType="top.stillmisty.xiantao.domain.item.entity.ItemTemplate">
        SELECT * FROM xt_item_template
        WHERE tags ?| ARRAY[
            <foreach collection="tags" item="tag" separator=",">
                #{tag}
            </foreach>
        ]
    </select>

    <!-- 根据多个标签查找物品模板（包含所有标签，使用 ?& 操作符） -->
    <select id="selectByAllTags" resultType="top.stillmisty.xiantao.domain.item.entity.ItemTemplate">
        SELECT * FROM xt_item_template
        WHERE tags ?&amp; ARRAY[
            <foreach collection="tags" item="tag" separator=",">
                #{tag}
            </foreach>
        ]
    </select>

</mapper>
