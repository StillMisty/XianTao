      <mxGeometry x="1080" y="40" width="80" height="60" as="geometry"/>
    </mxCell>
    
    <!-- Lifelines -->
    <mxCell id="lifeline-actor" value="" style="endArrow=none;html=1;dashed=1;" edge="1" parent="1">
