<mxfile host="Electron" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) draw.io/29.6.6 Chrome/144.0.7559.236 Electron/40.8.4 Safari/537.36" version="29.6.6">
  <diagram id="exploration-use-case" name="探索流程用例图">
    <mxGraphModel dx="1425" dy="862" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="system-boundary" parent="1" style="swimlane;whiteSpace=wrap;html=1;startSize=30;fillColor=#f5f5f5;fontColor=#333333;strokeColor=#666666;" value="修仙世界游戏系统 (Game System)" vertex="1">
          <mxGeometry height="580" width="560" x="180" y="40" as="geometry" />
        </mxCell>
        <mxCell id="uc-explore" parent="system-boundary" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1" value="地图探索&#xa;(Explore Map)" vertex="1">
          <mxGeometry height="60" width="140" x="40" y="210" as="geometry" />
        </mxCell>
        <mxCell id="uc-check-stamina" parent="system-boundary" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="检查体力值&#xa;(Check Stamina)" vertex="1">
          <mxGeometry height="60" width="140" x="40" y="400" as="geometry" />
        </mxCell>
        <mxCell id="uc-calc-reward" parent="system-boundary" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="计算探索奖励&#xa;(Calculate Reward)" vertex="1">
          <mxGeometry height="60" width="140" x="280" y="150" as="geometry" />
        </mxCell>
        <mxCell id="uc-update-pos" parent="system-boundary" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="更新当前位置&#xa;(Update Position)" vertex="1">
          <mxGeometry height="60" width="140" x="280" y="290" as="geometry" />
        </mxCell>
        <mxCell id="uc-handle-no-stamina" parent="system-boundary" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" value="提示体力不足&#xa;(Prompt No Stamina)" vertex="1">
          <mxGeometry height="50" width="130" x="290" y="410" as="geometry" />
        </mxCell>
        <mxCell id="edge-explore-check" edge="1" parent="system-boundary" source="uc-explore" style="endArrow=open;endSize=10;dashed=1;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;rounded=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" target="uc-check-stamina" value="&amp;lt;&amp;lt;include&amp;gt;&amp;gt;">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="110" y="320" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="edge-explore-calc" edge="1" parent="system-boundary" source="uc-explore" style="endArrow=open;endSize=10;dashed=1;html=1;exitX=1;exitY=0;entryX=0;entryY=0.5;" target="uc-calc-reward" value="&amp;lt;&amp;lt;include&amp;gt;&amp;gt;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-explore-update" edge="1" parent="system-boundary" source="uc-explore" style="endArrow=open;endSize=10;dashed=1;html=1;exitX=1;exitY=1;entryX=0;entryY=0.5;" target="uc-update-pos" value="&amp;lt;&amp;lt;include&amp;gt;&amp;gt;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-extend-no-stamina" edge="1" parent="system-boundary" source="uc-handle-no-stamina" style="endArrow=open;endSize=10;dashed=1;html=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;entryDx=0;entryDy=0;exitDx=0;exitDy=0;" target="uc-check-stamina" value="&amp;lt;&amp;lt;extend&amp;gt;&amp;gt;">
          <mxGeometry relative="1" x="0.0007" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="actor-player" parent="1" style="shape=umlActor;verticalLabelPosition=bottom;labelBackgroundColor=#ffffff;verticalAlign=top;html=1;outlineConnect=0;fillColor=#d5e8d4;strokeColor=#82b366;" value="玩家&#xa;(Player)" vertex="1">
          <mxGeometry height="80" width="40" x="60" y="260" as="geometry" />
        </mxCell>
        <mxCell id="edge-player-explore" edge="1" parent="1" source="actor-player" style="endArrow=none;html=1;entryX=0;entryY=0.5;exitX=1;exitY=0.3333;" target="uc-explore">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
