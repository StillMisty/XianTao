        <!-- ==================== Extend 扩展关系连线 ==================== -->
        <mxCell id="edge-extend-cooldown" value="&amp;lt;&amp;lt;extend&amp;gt;&amp;gt;&#xa;[冷却中]" style="endArrow=open;endSize=10;dashed=1;html=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;" parent="system-boundary" source="uc-prompt-cooldown" target="uc-check-cooldown" edge="1">
