        <mxCell id="edge-player-cancel" style="endArrow=none;html=1;entryX=0;entryY=0.5;exitX=1;exitY=0.3333;" parent="1" source="actor-player" target="uc-cancel-protection" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ==================== Include 包含关系连线 ==================== -->
        <mxCell id="edge-reset-cooldown" value="&amp;lt;&amp;lt;include&amp;gt;&amp;gt;" style="endArrow=open;endSize=10;dashed=1;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" parent="system-boundary" source="uc-reset-points" target="uc-check-cooldown" edge="1">
