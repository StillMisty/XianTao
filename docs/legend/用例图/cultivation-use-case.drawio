<mxfile host="app.diagrams.net" modified="2023-10-27T10:00:00.000Z" agent="Mozilla/5.0" version="22.1.22" type="device">
  <diagram id="cultivation-use-case-optimized" name="Cultivation Use Case">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- 系统边界 -->
        <mxCell id="system-boundary" value="修仙核心玩法系统 (Cultivation System)" style="swimlane;whiteSpace=wrap;html=1;startSize=30;fillColor=#f5f5f5;fontColor=#333333;strokeColor=#666666;" parent="1" vertex="1">
          <mxGeometry x="160" y="40" width="840" height="700" as="geometry" />
        </mxCell>

        <!-- 参与者 -->
        <mxCell id="actor-player" value="玩家&#xa;(Player)" style="shape=umlActor;verticalLabelPosition=bottom;labelBackgroundColor=#ffffff;verticalAlign=top;html=1;outlineConnect=0;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
          <mxGeometry x="40" y="350" width="40" height="80" as="geometry" />
        </mxCell>

        <!-- ==================== 主用例 (左列，玩家直接交互) ==================== -->
        <mxCell id="uc-query-status" value="查询修炼状态&#xa;(Query Status)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="system-boundary" vertex="1">
          <mxGeometry x="80" y="60" width="140" height="60" as="geometry" />
        </mxCell>

        <mxCell id="uc-allocate-points" value="属性加点&#xa;(Allocate Points)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="system-boundary" vertex="1">
          <mxGeometry x="80" y="150" width="140" height="60" as="geometry" />
        </mxCell>

        <mxCell id="uc-reset-points" value="散功重修 (洗点)&#xa;(Reset Attributes)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1" parent="system-boundary" vertex="1">
          <mxGeometry x="80" y="260" width="140" height="60" as="geometry" />
        </mxCell>

        <mxCell id="uc-breakthrough" value="突破境界&#xa;(Breakthrough)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1" parent="system-boundary" vertex="1">
          <mxGeometry x="80" y="400" width="140" height="60" as="geometry" />
        </mxCell>

        <mxCell id="uc-dao-protection" value="建立护道契约&#xa;(Establish Protection)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="system-boundary" vertex="1">
          <mxGeometry x="80" y="530" width="140" height="60" as="geometry" />
        </mxCell>

        <mxCell id="uc-cancel-protection" value="解除护道契约&#xa;(Cancel Protection)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="system-boundary" vertex="1">
          <mxGeometry x="80" y="610" width="140" height="60" as="geometry" />
        </mxCell>

        <!-- ==================== 子用例/内部规则 (中列，Include) ==================== -->
        <mxCell id="uc-check-cooldown" value="检查洗点冷却&#xa;(Check Cooldown)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" parent="system-boundary" vertex="1">
          <mxGeometry x="380" y="260" width="140" height="60" as="geometry" />
        </mxCell>

        <mxCell id="uc-calc-success-rate" value="计算突破成功率&#xa;(Calc Success Rate)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" parent="system-boundary" vertex="1">
          <mxGeometry x="380" y="360" width="140" height="60" as="geometry" />
        </mxCell>

        <mxCell id="uc-check-location" value="校验同地点护道者&#xa;(Check Location)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" parent="system-boundary" vertex="1">
          <mxGeometry x="380" y="440" width="140" height="60" as="geometry" />
        </mxCell>

        <!-- ==================== 扩展用例/异常流 (右列，Extend) ==================== -->
        <mxCell id="uc-prompt-cooldown" value="提示冷却未满&#xa;(Prompt Cooldown)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" parent="system-boundary" vertex="1">
          <mxGeometry x="640" y="260" width="140" height="60" as="geometry" />
        </mxCell>

        <mxCell id="uc-breakthrough-fail" value="处理突破失败/雷劫&#xa;(Handle Failure)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" parent="system-boundary" vertex="1">
          <mxGeometry x="640" y="400" width="140" height="60" as="geometry" />
