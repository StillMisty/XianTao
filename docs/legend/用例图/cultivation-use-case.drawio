        <mxCell id="edge-extend-breakthrough" value="&amp;lt;&amp;lt;extend&amp;gt;&amp;gt;&#xa;[判定失败]" style="endArrow=open;endSize=10;dashed=1;html=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;" parent="system-boundary" source="uc-breakthrough-fail" target="uc-breakthrough" edge="1">
